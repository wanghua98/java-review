# 复制为 .env 后，将所有 CHANGE_ME 替换为随机强密码。
MYSQL_ROOT_PASSWORD=CHANGE_ME_mysql_root
DB_PASSWORD=CHANGE_ME_database
REDIS_PASSWORD=CHANGE_ME_redis
ADMIN_INITIAL_PASSWORD=CHANGE_ME_admin

# 至少32个随机字符，例如：openssl rand -base64 48
PREVIEW_SIGNING_SECRET=CHANGE_ME_at_least_32_random_characters

# 浏览器访问系统的外部地址；部署到域名后改为 https://files.example.com
APP_PUBLIC_BASE_URL=http://localhost:8080
HTTP_PORT=8080

# 通过 HTTPS 域名提供服务时必须改为 true；本地 HTTP 调试保持 false。
SA_TOKEN_COOKIE_SECURE=false

# 固定官方预构建镜像版本。该镜像仅提供 amd64，Apple Silicon 由 Docker Desktop 自动转译。
KKFILEVIEW_IMAGE=keking/kkfileview:4.1.0
KKFILEVIEW_PLATFORM=linux/amd64
